# 自管部署(docker-compose)用的环境变量。
# 用法:  cp .env.deploy.example .env   然后填下面的值。
# 注意:.env 含密钥,别提交进 git(已在 .gitignore)。

# 服务端口令(客户端鉴权 + 应急密码登录)。生成:openssl rand -hex 24
CRAFT_SERVER_TOKEN=

# 飞书自建应用凭证(飞书开放平台后台拿)
CRAFT_FEISHU_APP_ID=cli_xxxxxxxx
CRAFT_FEISHU_APP_SECRET=

# 你的公开域名,必须是 wss:// 开头(Cloudflare Tunnel 绑的那个子域名)
CRAFT_WEBUI_WS_URL=wss://agent.你的域名.com

# Cloudflare Tunnel 令牌(在 Cloudflare Zero Trust 建 tunnel 时给你的那串)
CLOUDFLARE_TUNNEL_TOKEN=
