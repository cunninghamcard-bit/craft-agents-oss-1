# 全 Docker 部署的密钥/配置。用法：cp .env.docker.example .env 然后填值。
# .env 含密钥，已被 .gitignore 忽略，别提交。

# --- 服务端 ---
CRAFT_SERVER_TOKEN=            # openssl rand -hex 24 生成；应急/管理员浏览器登录用
CRAFT_WEBUI_WS_URL=wss://agent.inotoday.asia   # 浏览器回连地址，必须 wss + 你的域名

# --- 飞书登录 ---
CRAFT_FEISHU_AUTH_ENABLED=true
CRAFT_FEISHU_DOMAIN=feishu
CRAFT_FEISHU_APP_ID=cli_xxxxxxxx
CRAFT_FEISHU_APP_SECRET=
CRAFT_FEISHU_PASSWORD_FALLBACK=true   # 保留 token 登录后备；正式可设 false

# 注：CLOAKBROWSER_PROXY 在 docker-compose.yml 里已设为 http://mihomo:7899，不用填这里。
# 住宅代理账号、Clash 订阅 不在这里，而在 deploy/mihomo.yaml（见 deploy/mihomo.example.yaml）。
