# =============================================================================
# Dockerfile.full —— craft-agents 全功能镜像（一份"服务器装了什么"的清单）
#
# 在 Dockerfile.server 基础上额外打包：
#   - lark-cli (@larksuite/cli)          飞书 Base 操作
#   - uv + CloakBrowser + Chromium       国外平台采集（带系统库）
#   - mihomo                             代理内核（容器内也放一份，便于排查）
#   - procurement-agent 的 skill         采集/飞书 skill（构建前由脚本暂存进 build-skills/）
#
# 不进镜像（见 docker-compose.yml / .env.docker）：
#   - 密钥（token、飞书 Secret、隧道 token、住宅代理账号、Clash 订阅）→ env
#   - 持久数据（~/.craft-agent、lark-cli 登录态）→ 卷
#   - GFW 出口 → 独立 mihomo 容器
#
# 构建：scripts/build-and-deploy.sh（本机构建后传服务器）。需 4G+ 内存、好网络。
# =============================================================================
FROM oven/bun:1.3-slim

LABEL org.opencontainers.image.description="Craft Agents Server (full: +lark-cli +cloakbrowser +skills)"

# --- 系统依赖 + Node + Chromium 运行所需系统库 ---
ARG NODE_MAJOR=20
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates git ripgrep fd-find curl gnupg gosu unzip xz-utils \
      # CloakBrowser/Chromium 运行所需（playwright install-deps 的等价集）
      libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
      libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 \
      libgbm1 libasound2 libpango-1.0-0 libcairo2 libatspi2.0-0 \
      fonts-liberation fonts-noto-cjk && \
    curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# skill 脚本用 `python` 与 `fd`：镜像里实为 python3 / fdfind，补软链，
# 否则飞书表格 skill 报 `python: command not found`，Find 工具去 GitHub 下 fd 撞墙。
RUN ln -sf /usr/bin/python3 /usr/local/bin/python && \
    ln -sf "$(command -v fdfind)" /usr/local/bin/fd

# --- 非 root 用户（Claude SDK 拒绝 root）---
RUN groupadd -r craftagents && \
    useradd -r -g craftagents -m -d /home/craftagents -s /bin/bash craftagents

# 构建时走代理下载 GitHub/海外资源（本机 clash）。bun/pip 用国内镜像，不走这个。
ARG HTTPS_PROXY=
ARG HTTP_PROXY=

WORKDIR /app

# --- 依赖清单（层缓存）---
COPY package.json bun.lock bunfig.toml ./
COPY packages/server/package.json packages/server/
COPY packages/server-core/package.json packages/server-core/
COPY packages/shared/package.json packages/shared/
COPY packages/core/package.json packages/core/
COPY packages/session-tools-core/package.json packages/session-tools-core/
COPY packages/session-mcp-server/package.json packages/session-mcp-server/
COPY packages/pi-agent-server/package.json packages/pi-agent-server/
COPY packages/ui/package.json packages/ui/
COPY packages/messaging-gateway/package.json packages/messaging-gateway/
COPY packages/messaging-whatsapp-worker/package.json packages/messaging-whatsapp-worker/
COPY apps/cli/package.json apps/cli/
COPY apps/viewer/package.json apps/viewer/
COPY apps/webui/package.json apps/webui/

# 用国内镜像装依赖（构建机在国内也快）
ARG NPM_REGISTRY=https://registry.npmmirror.com
RUN BUN_CONFIG_REGISTRY=$NPM_REGISTRY bun install --frozen-lockfile

# --- 源码 + 构建 ---
COPY . .
RUN bun build packages/session-mcp-server/src/index.ts \
      --outfile packages/session-mcp-server/dist/index.js --target node --format cjs && \
    bun build packages/pi-agent-server/src/index.ts \
      --outfile packages/pi-agent-server/dist/index.js --target node --format cjs && \
    bun run scripts/build-wa-worker.ts && \
    NODE_OPTIONS="--max-old-space-size=4096" bunx vite build --config apps/webui/vite.config.ts

# --- lark-cli（以 root 装到 /usr/local，所有用户可用；非 root 全局装有 EACCES 问题）---
RUN BUN_INSTALL=/usr/local BUN_CONFIG_REGISTRY=$NPM_REGISTRY bun install -g @larksuite/cli@1.0.40 && \
    lark-cli --version && \
    chmod -R a+rX /usr/local/install/global

# --- uv ---
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh && \
    /usr/local/bin/uv --version

# --- CloakBrowser + Chromium（craftagents）---
# cloakbrowser 包不在国内镜像（清华返回 403），用官方 PyPI；构建期经 clash 代理
# （HTTPS_PROXY build-arg + --network=host）。Chromium 下载同样走代理。
USER craftagents
# UV_HTTP_TIMEOUT bumps uv's per-request timeout (default 30s) — pythonhosted.org
# via clash is slow and was timing out on large wheels (aiohttp). 180s + retries.
RUN HOME=/home/craftagents UV_HTTP_TIMEOUT=180 /usr/local/bin/uv tool install --with "httpx[socks]" --with geoip2 cloakbrowser && \
    HOME=/home/craftagents /home/craftagents/.local/share/uv/tools/cloakbrowser/bin/cloakbrowser install
USER root
# cloakbrowser-python wrapper（venv python 直跑，符合 SKILL.md 里的硬编码路径）
RUN printf '#!/bin/sh\nexec /home/craftagents/.local/share/uv/tools/cloakbrowser/bin/python "$@"\n' \
      > /usr/local/bin/cloakbrowser-python && chmod 755 /usr/local/bin/cloakbrowser-python

# --- skill（构建脚本把 procurement-agent/.agents/skills 暂存到 build-skills/）---
COPY --chown=craftagents:craftagents build-skills/ /home/craftagents/.agents/skills/

# --- 工作区权限白名单 ---
# 只读(Explore)模式下放行 skill 脚本命令（cloakbrowser-python/python/node/lark-cli）。
# 代码用 {workspaceRootPath}/permissions.json，workspace rootPath=~=/home/craftagents，
# 故必须放这里（不是 .craft-agent/workspaces/...，那是过时的文档路径）。
COPY --chown=craftagents:craftagents deploy/permissions.json /home/craftagents/permissions.json

# --- 权限 + 预建数据目录 ---
RUN mkdir -p /home/craftagents/.craft-agent && \
    find /app -not -perm -o=r -exec chmod o+r {} + && \
    find /app -type d -not -perm -o=x -exec chmod o+x {} + && \
    chmod -R 777 /home/craftagents

# --- 运行时环境（不含密钥，密钥走 env）---
ENV CRAFT_RPC_HOST=0.0.0.0 \
    CRAFT_RPC_PORT=9100 \
    CRAFT_WEBUI_DIR=/app/apps/webui/dist \
    CRAFT_BUNDLED_ASSETS_ROOT=/app \
    CRAFT_IS_PACKAGED=false \
    CRAFT_CONFIG_DIR=/home/craftagents/.craft-agent \
    CRAFT_DEFAULT_WORKSPACE_PATH=/home/craftagents \
    HOME=/home/craftagents \
    PATH=/home/craftagents/.bun/bin:/home/craftagents/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin \
    CRAFT_MESSAGING_WA_WORKER=/app/packages/messaging-whatsapp-worker/dist/worker.cjs \
    CRAFT_MESSAGING_NODE_BIN=node

EXPOSE 9100
RUN chmod +x /app/scripts/server-entrypoint-full.sh
ENTRYPOINT ["/app/scripts/server-entrypoint-full.sh"]
CMD ["bun", "run", "packages/server/src/index.ts"]
