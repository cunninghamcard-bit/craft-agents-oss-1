        <div class="source-panel">
          <h3>Mermaid Source</h3>
          <pre><code>classDiagram
  class Animal {
    &lt;&lt;abstract&gt;&gt;
    +String name
    +int age
    +eat() void
  }
  class Dog {
    +String breed
    +bark() void
  }
  class Cat {
    +bool isIndoor
    +meow() void
  }
  Animal &lt;|-- Dog
  Animal &lt;|-- Cat</code></pre>
