    B --&gt; E[User Service]
    B --&gt; F[Order Service]
  end
  subgraph data [Data Layer]
    D --&gt; G[(Auth DB)]
    E --&gt; H[(User DB)]
    F --&gt; I[(Order DB)]
  end</code></pre>
