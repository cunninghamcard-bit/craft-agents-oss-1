# Development secrets via 1Password CLI
# Requires: brew install 1password-cli && op signin
#
# Usage: bun run electron:start (auto-injects secrets via op run)
# Fallback: Create .env with actual values for local override

# Google OAuth (for Gmail, Calendar, Drive connection features)
GOOGLE_OAUTH_CLIENT_ID=op://Dev_Craft_Agents/Craft Agent Gmail OAuth/client_id
GOOGLE_OAUTH_CLIENT_SECRET=op://Dev_Craft_Agents/Craft Agent Gmail OAuth/client_secret

# Slack OAuth (for Slack workspace integration)
SLACK_OAUTH_CLIENT_ID=op://Dev_Craft_Agents/Craft Agent Slack OAuth/client_id
SLACK_OAUTH_CLIENT_SECRET=op://Dev_Craft_Agents/Craft Agent Slack OAuth/client_secret
