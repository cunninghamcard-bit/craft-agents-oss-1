{
  "name": "craft-tui-agent",
  "version": "1.0.0",
  "description": "Claude Code-like agent for Craft documents",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "bin": {
    "craft": "./apps/tui/src/index.tsx"
  },
  "scripts": {
    "start": "bun run apps/tui/src/index.tsx",
    "dev": "bun --watch run apps/tui/src/index.tsx",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "bun run typecheck && cd packages/core && bun run tsc --noEmit && cd ../session-manager && bun run tsc --noEmit",
    "link": "bun link",
    "electron:build:main": "esbuild apps/electron/src/main/index.ts --bundle --platform=node --format=cjs --outfile=apps/electron/dist/main.cjs --external:electron",
    "electron:build:preload": "esbuild apps/electron/src/preload/index.ts --bundle --platform=node --format=cjs --outfile=apps/electron/dist/preload.cjs --external:electron",
    "electron:build:renderer": "vite build --config apps/electron/vite.config.ts",
    "electron:build:resources": "cp -r apps/electron/resources apps/electron/dist/",
    "electron:build": "bun run electron:build:main && bun run electron:build:preload && bun run electron:build:renderer && bun run electron:build:resources",
    "electron:start": "bun run electron:build && electron apps/electron",
    "electron:dev": "vite dev --config apps/electron/vite.config.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.947.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "electron": "^39.2.7",
    "esbuild": "^0.24.0",
    "postcss": "^8.5.6",
    "react-devtools-core": "^6.1.1",
    "tailwindcss": "^4.1.18",
    "tar": "^7.5.2",
    "typescript": "^5.0.0",
    "vite": "^6.2.4"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.62",
    "@anthropic-ai/sdk": "^0.71.1",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@shikijs/cli": "^3.19.0",
    "chalk": "5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ink": "^5.0.0",
    "jotai": "^2.16.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.561.0",
    "marked": "^17.0.1",
    "marked-terminal": "^7.3.0",
    "meow": "^14.0.0",
    "open": "^11.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-resizable-panels": "^3.0.6",
    "shiki": "^3.19.0",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.1"
  }
}
